---
import Layout from '../layouts/Layout.astro'
import Hero from '../components/organisms/Hero.astro'
import ProductShowcase from '../components/organisms/ProductShowcase.astro'
import About from '../components/organisms/About.astro'
import BlurText from '../components/atoms/react-bits/BlurText.jsx'
import { getProducts } from '../lib/api/products.ts'

const products = await getProducts()
const countdownTarget = import.meta.env.PUBLIC_COUNTDOWN_TARGET_DATE
---

<Layout>
  <Hero targetDate={countdownTarget}>
  </Hero>

  <ProductShowcase products={products} />

  <About />
</Layout>
