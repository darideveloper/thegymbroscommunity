---
import Layout from '../layouts/Layout.astro'
import Hero from '../components/organisms/Hero.astro'
import ProductShowcase from '../components/organisms/ProductShowcase.astro'
import About from '../components/organisms/About.astro'
import { getProducts } from '../lib/api/products.ts'
import LiquidEther from '../components/organisms/react-bits/LiquidEther.jsx'
import BaseSEO from '../components/utils/base/BaseSEO.astro'

const products = await getProducts()
const countdownTarget = import.meta.env.PUBLIC_COUNTDOWN_TARGET_DATE

const productList = products.map(p => ({
  name: p.text,
  image: p.image
}));
---

<Layout>
  <BaseSEO 
    slot="seo"
    jsonType="OnlineStore"
    productList={productList}
  />

  <Hero targetDate={countdownTarget} />

  <ProductShowcase products={products} />

  <About />

  <div class='fixed inset-0 z-[-10]'>
    <LiquidEther
      mouseForce={20}
      cursorSize={100}
      isViscous
      viscous={30}
      colors={['#66240c', '#260d04', '#783117']}
      autoDemo
      autoSpeed={0.5}
      autoIntensity={2.2}
      isBounce={false}
      resolution={0.5}
      client:only='react'
    />
  </div>
</Layout>
