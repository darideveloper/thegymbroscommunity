---
import LaserFlow from '../molecules/react-bits/LaserFlow.jsx'
import Countdown from '../molecules/Countdown.jsx'

const { targetDate } = Astro.props
---

<section class='relative w-full overflow-hidden'>
  <div class='flex flex-col items-center w-full py-12 gap-8'>
    <slot />

    <Countdown
      targetDate={targetDate}
      className='w-full mt-12 md:mt-24 mb-12 md:mb-20 px-4'
      client:only='react'
    />
  </div>

  <div
    class='w-auto md:w-screen h-[80vh] md:h-screen -mt-[80vh] relative'
  >
    <LaserFlow
      color='#ca3500'
      flowSpeed={0.84}
      verticalSizing={24}
      horizontalSizing={1.6}
      fogIntensity={0.55}
      fogScale={0.6}
      wispSpeed={15}
      wispIntensity={5}
      flowStrength={0.13}
      decay={1.1}
      horizontalBeamOffset={0}
      verticalBeamOffset={-0.5}
      transparent={true}
      client:only='react'
      className='-z-10'
    />
  </div>
</section>
