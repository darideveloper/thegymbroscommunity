---
import TGCLogo from '../atoms/TGCLogo.astro';
import GlowNavigationDrawer from './GlowNavigationDrawer';
import BlurText from '../atoms/react-bits/BlurText.jsx';

const menuItems = [
  { label: 'Inicio', link: '/' },
  { label: 'Productos', link: '/#products' },
  { label: 'Acerca de', link: '/#about' },
];

const socialItems = [
  { label: 'EL GRAM', link: 'https://instagram.com' },
  { label: 'EL FEED', link: 'https://twitter.com' },
  { label: 'ESTACIÓN DE MANDO', link: 'https://discord.com' },
];
---

<header 
  id="main-header"
  class="group fixed top-0 left-0 w-full z-50 transition-all duration-300 py-6 px-6 md:px-12"
>
  <div class="max-w-7xl mx-auto flex justify-between items-center">
    <div class="flex items-center gap-4">
      <TGCLogo class="group-data-[scrolled=true]:scale-75 origin-left" />
      <h1 
        id="header-title-container" 
        class="-mt-2 font-heading font-black text-[0.7875rem] sm:text-3xl text-primary transition-all duration-300 group-data-[scrolled=true]:text-[0.49rem] sm:group-data-[scrolled=true]:text-[1.05rem]"
      >
        <BlurText
          text="The Gym Bros Community"
          delay={150}
          animateBy="words"
          className="text-primary font-heading font-black tracking-tighter transition-all duration-300"
          client:only="react"
        />
      </h1>
    </div>

    <div class="flex items-center">
      <GlowNavigationDrawer 
        client:load 
        items={menuItems} 
        socialItems={socialItems}
      />
    </div>
  </div>
</header>

<style>
  #header-title-container :global(span),
  #header-title-container :global(p) {
    font-size: inherit !important;
    transition: all 0.3s ease-in-out;
  }
</style>

<script>
  const header = document.getElementById('main-header');
  
  const handleScroll = () => {
    if (window.scrollY > 50) {
      header?.setAttribute('data-scrolled', 'true');
      header?.classList.add('bg-black/80', 'backdrop-blur-md', 'py-4', 'shadow-lg');
      header?.classList.remove('py-6');
    } else {
      header?.removeAttribute('data-scrolled');
      header?.classList.remove('bg-black/80', 'backdrop-blur-md', 'py-4', 'shadow-lg');
      header?.classList.add('py-6');
    }
  };

  window.addEventListener('scroll', handleScroll);
  // Initial check
  handleScroll();
</script>
