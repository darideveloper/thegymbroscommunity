---
import BlurText from '../atoms/react-bits/BlurText.jsx';
import GlowSidemenuNav from './GlowSidemenuNav';

const menuItems = [
  { label: 'Home', ariaLabel: 'Go to home page', link: '/' },
  { label: 'About', ariaLabel: 'Learn about us', link: '/about' },
  { label: 'Services', ariaLabel: 'View our services', link: '/services' },
  { label: 'Contact', ariaLabel: 'Get in touch', link: '/contact' },
]

const socialItems = [
  { label: 'Twitter', link: 'https://twitter.com' },
  { label: 'GitHub', link: 'https://github.com' },
  { label: 'LinkedIn', link: 'https://linkedin.com' },
]
---

<header 
  id="main-header" 
  class="group fixed top-0 left-0 w-full z-[100] transition-all duration-300 ease-in-out px-8 py-8 grid grid-cols-3 items-center bg-black/30 backdrop-blur-md border-b border-white/10 bg-linear-135 from-white/5 to-white/1 shadow-[0_4px_30px_rgba(0,0,0,0.5),inset_0_0_10px_rgba(255,255,255,0.05)] data-[scrolled=true]:py-2 data-[scrolled=true]:bg-black/80 data-[scrolled=true]:backdrop-blur-[24px]"
>
  <div class="flex items-center justify-self-start">
    <a href="/" class="group/logo">
      <img 
        src="/assets/logo.webp" 
        alt="TGC Logo" 
        id="header-logo" 
        class="w-20 h-20 transition-all duration-300 group-hover/logo:scale-110 group-data-[scrolled=true]:w-10 group-data-[scrolled=true]:h-10" 
      />
    </a>
  </div>
  
  <div class="flex items-center justify-center">
    <h1 
      id="header-title-container" 
      class="font-black text-lg sm:text-3xl text-primary transition-all duration-300 text-center group-data-[scrolled=true]:text-[0.7rem] sm:group-data-[scrolled=true]:text-[1.05rem]"
    >
      <BlurText
        text="The Gym Bros Community"
        delay={150}
        animateBy="words"
        className="text-primary font-black uppercase tracking-tighter justify-center transition-all duration-300"
        client:only="react"
      />
    </h1>
  </div>

  <div class="flex items-center justify-self-end">
    <GlowSidemenuNav 
      items={menuItems} 
      socialItems={socialItems} 
      className="z-50"
      client:load
    />
  </div>
</header>

<script>
  const header = document.getElementById('main-header');
  
  const handleScroll = () => {
    if (window.scrollY > 50) {
      header?.setAttribute('data-scrolled', 'true');
    } else {
      header?.removeAttribute('data-scrolled');
    }
  };

  window.addEventListener('scroll', handleScroll);
  // Initial check
  handleScroll();
</script>
